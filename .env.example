# ── CESIZen API — Variables d'environnement ──────────────────────────────────
# Copier ce fichier en ".env" et remplir les valeurs
# Le fichier .env ne doit JAMAIS être commité (il est dans .gitignore)

# ── Base de données ───────────────────────────────────────────────────────────
# En Docker : DB_HOST=db (nom du service dans docker-compose)
# En local  : DB_HOST=localhost
DB_HOST=db

# Nom de la base selon l'environnement :
#   dev  → cesizen_dev
#   prod → cesizen_prod
MYSQL_DATABASE=cesizen_dev

DB_USERNAME=cesizen_app
DB_PASSWORD=change_me_strong_password

# Mot de passe root MySQL (utilisé uniquement par phpMyAdmin en dev)
MYSQL_ROOT_PASSWORD=change_me_root_password

# Mot de passe du compte MySQL de supervision (mysqld-exporter).
# Compte distinct de root, limité à PROCESS / REPLICATION CLIENT et à la
# lecture de performance_schema — aucun accès aux données applicatives.
MYSQL_EXPORTER_PASSWORD=change_me_exporter_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 64
JWT_SECRET=change_me_generate_a_random_256bit_secret
JWT_EXPIRATION=86400000

# ── Email SMTP ────────────────────────────────────────────────────────────────
MAIL_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre_email@gmail.com
MAIL_PASSWORD=votre_app_password_gmail

# ── Application ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
SPRING_PROFILES_ACTIVE=dev

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password
